# Copy this file to .env.local for local use.
# Do not commit .env.local with real secrets.

SERVER_PORT=8083

# MongoDB
MONGODB_URI=mongodb://admin:CHANGE_ME@localhost:27017/customerdb?authSource=admin

# Keycloak / OIDC
OIDC_REALM=customer-microservice
OIDC_ISSUER_URI=http://localhost:8180/realms/customer-microservice

# Local Keycloak admin account.
# Use only for local Docker development.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME

# Local test user created in Keycloak.
KEYCLOAK_TEST_CLIENT_ID=postman-client
KEYCLOAK_TEST_USERNAME=customer1
KEYCLOAK_TEST_PASSWORD=CHANGE_ME
